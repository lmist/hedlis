{
  "name": "cloak",
  "version": "1.0.0",
  "description": "Patchright runner with required OpenCLI extension and Chrome cookie support",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "cloak": "bin/cloak.js"
  },
  "files": [
    "bin",
    "dist",
    "scripts/postinstall.cjs",
    "src",
    "README.org"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "build": "node ./node_modules/typescript/bin/tsc --project tsconfig.build.json",
    "prepack": "npm run build",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "start": "node --import tsx src/main.ts",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "chalk": "^4.1.2",
    "chrome-cookies-secure": "^3.0.1",
    "patchright": "^1.58.2",
    "tsx": "^4.21.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20.0.0",
    "@types/yargs": "^17.0.33",
    "typescript": "^5.3.0"
  }
}
