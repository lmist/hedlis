{
  "name": "@lmist/cloak",
  "version": "2.0.1",
  "description": "Chrome sidecar for OpenCLI with daemonized Patchright startup and remembered cookie URLs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lmist/cloak.git"
  },
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "cloak": "bin/cloak.js"
  },
  "files": [
    "bin",
    "dist",
    ".githooks/pre-commit",
    ".githooks/pre-push",
    "scripts/postinstall.cjs",
    "scripts/render-readme.cjs",
    "scripts/setup-git-hooks.cjs",
    "docs/assets/cloak-logo-readme-centered.png",
    "src/app-paths.ts",
    "src/chrome-cookies.ts",
    "src/chrome-profile-sites.ts",
    "src/chrome-profiles.ts",
    "src/cli.ts",
    "src/cookies.ts",
    "src/daemon.ts",
    "src/extension.ts",
    "src/install-extension.ts",
    "src/main.ts",
    "src/output.ts",
    "src/state-db.ts",
    "README.md",
    "README.org"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "build": "node scripts/build.cjs",
    "render-readme": "node scripts/render-readme.cjs",
    "check-readme": "node scripts/render-readme.cjs --check",
    "prepack": "npm run build",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "start": "node --import tsx src/main.ts",
    "test": "node --import tsx --test src/**/*.test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "chalk": "^4.1.2",
    "patchright": "^1.58.2",
    "tsx": "^4.21.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20.0.0",
    "@types/yargs": "^17.0.33",
    "typescript": "^5.3.0"
  }
}
